# ==========================================
# PYTHON / DJANGO
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/

# Виртуальные окружения (мы используем Docker, но оставляем на случай локальной отладки)
venv/
env/
.venv/

# Django
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Медиа и собранная статика (загружаются пользователями или генерируются автоматически)
media/
staticfiles/

# ==========================================
# NEXT.JS / NODE
# ==========================================
# Зависимости (скачиваются командой npm install)
node_modules/

# Сборка Next.js (генерируется при деплое)
.next/
out/

# Логи отладки
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# СЕКРЕТЫ И НАСТРОЙКИ
# ==========================================
.env
.env.local
.env.*.local
.env.production
.env.development
.env.example

# ==========================================
# РЕДАКТОРЫ И ОС
# ==========================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ==========================================
# ПРОЧЕЕ
